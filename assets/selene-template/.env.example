# Environment configuration for Selene quantum service
# Copy this file to .env and fill in values

# Port (Fly.io sets PORT automatically)
PORT=8080

# Quantum hardware configuration
# QUANTUM_HARDWARE=h2  # Options: h2, h1, emulator
# QUANTUM_API_KEY=your_quantinuum_api_key_here  # Only needed for real hardware

# API authentication (optional)
# API_KEY=your_selene_api_key_here

# Job queue (for production with Redis)
# REDIS_URL=redis://localhost:6379

# Debug mode
DEBUG=false

# Logging
LOG_LEVEL=INFO
